rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // This document only. Subcollections need their own rules — a broad
    // `{document=**}` grant would OR with the notes rules and re-permit the
    // hard deletes they exist to prevent.
    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/notes/{noteId} {

      function hasNoteShape() {
        let d = request.resource.data;
        return d.keys().hasOnly(['id', 'ownerId', 'title', 'content',
                                 'createdAt', 'updatedAt', 'deletedAt'])
            && d.keys().hasAll(['id', 'ownerId', 'title', 'content',
                                'createdAt', 'updatedAt', 'deletedAt'])
            && d.id == noteId
            && d.ownerId == uid
            && d.title is string
            && d.title.size() <= 500
            && d.content is map
            && d.createdAt is timestamp
            && d.updatedAt is timestamp
            && (d.deletedAt == null || d.deletedAt is timestamp);
      }

      // deletedAt must be present and null, never absent: `== null` does not
      // match documents missing the field, so an absent value would make the
      // note permanently invisible to the `deletedAt == null` list query.
      function isLiveOnCreate() {
        return request.resource.data.deletedAt == null;
      }

      // The reap window below trusts deletedAt, so the client must not get to
      // choose it — a backdated value would make a note immediately reapable.
      // `== request.time` requires serverTimestamp() for this field (and only
      // this field; see CONTEXT.md). Carrying the existing value forward is
      // safe by induction: it was request.time when written.
      function isDeletedAtTrusted() {
        let next = request.resource.data.deletedAt;
        return next == null
            || next == request.time
            || next == resource.data.deletedAt;
      }

      // createdAt is set once. ownerId and id are denormalized copies of the
      // path, and anything reading them off the document should be able to
      // trust them.
      function isImmutablePreserved() {
        return request.resource.data.id == resource.data.id
            && request.resource.data.ownerId == resource.data.ownerId
            && request.resource.data.createdAt == resource.data.createdAt;
      }

      // Notes are soft-deleted via deletedAt (see CONTEXT.md). Hard delete is
      // only for reaping tombstones past their undo window.
      function isExpiredTombstone() {
        return resource.data.deletedAt != null
            && request.time > resource.data.deletedAt + duration.value(30, 'd');
      }

      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && hasNoteShape() && isLiveOnCreate();
      allow update: if isOwner(uid) && hasNoteShape()
                    && isImmutablePreserved() && isDeletedAtTrusted();
      allow delete: if isOwner(uid) && isExpiredTombstone();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
