rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // This document only. Subcollections need their own rules — a broad
    // `{document=**}` grant would OR with the notes rules and re-permit the
    // hard deletes they exist to prevent.
    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/notes/{noteId} {

      // deletedAt must be present and null, never absent: `== null` does not
      // match documents missing the field.
      function isLiveOnCreate() {
        return 'deletedAt' in request.resource.data
            && request.resource.data.deletedAt == null
            && request.resource.data.ownerId == uid;
      }

      // Notes are soft-deleted via deletedAt (see CONTEXT.md). Hard delete is
      // only for reaping tombstones past their undo window.
      function isExpiredTombstone() {
        return resource.data.deletedAt != null
            && request.time > resource.data.deletedAt + duration.value(30, 'd');
      }

      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isLiveOnCreate();
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid) && isExpiredTombstone();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
