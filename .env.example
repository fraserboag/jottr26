# Firebase project config (Project settings > General > Your apps > SDK setup and configuration)
# Copy this file to .env.local and fill in real values. Never commit .env.local.
VITE_FIREBASE_API_KEY=
# Locally, use the console value (jottr26.firebaseapp.com). Deployed builds
# override this in Vercel's env vars with the domain the app is served from.
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
